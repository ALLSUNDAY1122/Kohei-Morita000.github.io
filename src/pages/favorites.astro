---
import BaseLayout from "@layouts/BaseLayout.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import { collectionJsonLd } from "@lib/seo";
---

<BaseLayout title="お気に入り" description="この端末に保存したお気に入りの怖い話一覧です。" noindex jsonLd={collectionJsonLd("お気に入り", "/favorites/", "端末内に保存されたお気に入り一覧")}>
  <Breadcrumbs items={[{ href: "/favorites/", label: "お気に入り" }]} />
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Favorites</p>
      <h1>お気に入り</h1>
      <p>お気に入りはこの端末のブラウザに保存されます。別の端末やブラウザとは共有されません。</p>
      <p><strong data-favorites-count>0</strong>件保存中</p>
    </div>
  </section>
  <section class="section">
    <div class="container" data-favorites-list></div>
  </section>
</BaseLayout>
